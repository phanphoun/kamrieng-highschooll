{
    "name": "laravel/laravel",
    "type": "project",
    "description": "EduKhmer High School Management and Communications Platform",
    "keywords": ["laravel", "framework", "school", "management", "cambodia"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^11.54",
        "laravel/breeze": "^2.2",
        "livewire/livewire": "^3.5",
        "laravel/socialite": "^5.16",
        "spatie/laravel-permission": "^6.10",
        "laravel/scout": "^10.11",
        "intervention/image-laravel": "^1.5",
        "league/csv": "^9.21",
        "guzzlehttp/guzzle": "^7.9"
    },
    "require-dev": {
        "pestphp/pest": "^2.35",
        "laravel/dusk": "^8.2",
        "laravel/pint": "^1.18",
        "barryvdh/laravel-debugbar": "^3.14",
        "fakerphp/faker": "^1.24",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.5",
        "laravel/sail": "^1.39"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "policy": {
            "advisories": {
                "ignore": [
                    "PKSA-m5cs-t1y6-qpcs",
                    "PKSA-3r5d-mb8f-1qw9",
                    "PKSA-mdq4-51ck-6kdq",
                    "PKSA-8qx3-n5y5-vvnd",
                    "PKSA-q46n-4fdk-zjr4",
                    "PKSA-qzrn-rnz3-85w1",
                    "PKSA-w7xr-vk7n-rstm"
                ]
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
